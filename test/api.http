### Config
@baseUrl = http://localhost:3001/api

### --- CUSTOMERS ---

### Create Customer
POST {{baseUrl}}/customers
Content-Type: application/json

{
  "name": "John Doe",
  "email": "john@example.com",
  "phone": "0123456789",
  "address": "123 Main St"
}

### Get All Customers
GET {{baseUrl}}/customers

### Get Single Customer (Replace ID)
GET {{baseUrl}}/customers/ba5578ca-6c9d-45e3-a1f9-288e190ea8a8

### Update Customer (Replace ID)
PATCH {{baseUrl}}/customers/REPLACE_WITH_ID
Content-Type: application/json

{
  "name": "John Updated"
}

### Delete Customer (Replace ID)
DELETE {{baseUrl}}/customers/REPLACE_WITH_ID


### --- ORDERS ---

### Create Order
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "customerName": "John Doe",
  "totalAmount": 1500.50,
  "status": "pending"
}

### Get All Orders
GET {{baseUrl}}/orders

### Get Single Order (Replace ID)
GET {{baseUrl}}/orders/REPLACE_WITH_ID

### Update Order (Replace ID)
PATCH {{baseUrl}}/orders/REPLACE_WITH_ID
Content-Type: application/json

{
  "status": "completed"
}

### Delete Order (Replace ID)
DELETE {{baseUrl}}/orders/REPLACE_WITH_ID


### --- PRODUCTS ---

### Create Product
POST {{baseUrl}}/products
Content-Type: application/json

{
  "productName": "Laptop Dell",
  "productType": "Electronics"
}

### Get All Products
GET {{baseUrl}}/products

### Get Single Product (Replace ID)
GET {{baseUrl}}/products/REPLACE_WITH_ID

### Update Product (Replace ID)
PATCH {{baseUrl}}/products/REPLACE_WITH_ID
Content-Type: application/json

{
  "productName": "Laptop Dell XPS"
}

### Delete Product (Replace ID)
DELETE {{baseUrl}}/products/REPLACE_WITH_ID
